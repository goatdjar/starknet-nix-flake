# ==========================================
# Cairo & Scarb (Starknet)
# ==========================================
# Scarb compilation artifacts and target directories
target/
# Local cache directory explicitly set in your shellHook
.cache/

# ==========================================
# Nix & Development Environment
# ==========================================
# If you use direnv to auto-load your nix flake, ignore its environment state
.direnv/
# Explicitly DO NOT ignore flake.lock (it ensures reproducible builds)
!flake.lock

# ==========================================
# Node.js (starknet.js / deployment scripts)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==========================================
# Environment Variables & Secrets
# ==========================================
# NEVER commit private keys, seed phrases, or RPC URLs
.env
.env.local
.env.*.local
*.env

# ==========================================
# Operating System & IDEs
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db

# IDEs (VS Code, JetBrains)
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
